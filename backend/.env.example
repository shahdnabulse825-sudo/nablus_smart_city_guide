# انسخي هذا الملف إلى .env واملأي القيم الحقيقية
# قاعدة بيانات محلية حقيقية (ملف واحد جوا مجلد backend) — ما بتحتاجي تغيّري هاد السطر أبدًا
DATABASE_URL="file:./dev.db"

# مفتاح سري لتوقيع رموز الدخول (JWT) — غيّريه لأي نص عشوائي طويل
JWT_SECRET="غيّري-هاي-القيمة-لنص-سري-طويل-وعشوائي"

# بيانات حساب الأدمن الافتراضي (تُستخدم أول مرة فقط لإنشاء حساب الأدمن بقاعدة البيانات)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# المنفذ اللي بيشتغل عليه السيرفر محليًا
PORT=4000
